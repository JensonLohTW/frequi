# Used when build context is apps/frontend (upstream-style).
# Platform compose builds from monorepo root; see root .dockerignore + deploy/docker/frontend.Dockerfile.
.git
.env
.env.*
node_modules
dist
coverage
playwright-report
test-results
# Keep e2e/tsconfig.json (referenced by root tsconfig); drop specs/fixtures
e2e/**
!e2e/tsconfig.json
tests
*.md
.vscode
.idea
